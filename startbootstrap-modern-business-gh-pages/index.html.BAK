<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />

    <meta name="description" content="Barradev ofrece consultoría técnica en captura de datos, integración de sistemas, automatización de procesos, dashboards y soluciones de software a medida para PYMEs y equipos técnicos." />
    <meta name="author" content="Sergio Pernas" />

    <title>Barradev | Consultoría en datos, automatización y software a medida</title>

    <!-- Open Graph -->
    <meta property="og:title" content="Barradev | Consultoría en datos, automatización y software a medida" />
    <meta property="og:description" content="Soluciones técnicas para ordenar información, integrar sistemas, automatizar procesos y visualizar datos de forma clara." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://barradev.com.ar/" />
    <meta property="og:image" content="https://barradev.com.ar/assets/hero.png" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Barradev | Consultoría en datos, automatización y software a medida" />
    <meta name="twitter:description" content="Consultoría técnica en integración de datos, automatización de procesos, dashboards y desarrollo de soluciones a medida." />
    <meta name="twitter:image" content="https://barradev.com.ar/assets/hero.png" />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="assets/favicon.ico" />

    <!-- Bootstrap icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.5.0/font/bootstrap-icons.css" rel="stylesheet" />

    <!-- Core theme CSS -->
    <link href="css/styles.css" rel="stylesheet" />
</head>
    <body class="d-flex flex-column h-100">
        <main class="flex-shrink-0">
            <!-- Navigation-->
            <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
                <div class="container px-5">
                    <a class="navbar-brand" href="index.html">Barradev</a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation"><span class="navbar-toggler-icon"></span></button>
                    <div class="collapse navbar-collapse" id="navbarSupportedContent">
                        <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                            <li class="nav-item"><a class="nav-link" href="index.html">Home</a></li>
                            <li class="nav-item"><a class="nav-link" href="about.html">About</a></li>
                            <li class="nav-item"><a class="nav-link" href="contact.html">Contact</a></li>
                            <li class="nav-item"><a class="nav-link" href="https://labs.barradev.com.ar">Capacitaciones</a></li>
                            <li class="nav-item"><a class="nav-link" href="https://www.linkedin.com/in/sergio-pernas/">Linkedin</a></li>
                            <li class="nav-item"><a class="nav-link" href="https://www.youtube.com/@kcnrtfm">YouTube</a></li>
                        </ul>
                    </div>
                </div>
            </nav>
            <!-- Header-->
            <header class="bg-dark py-5">
                <div class="container px-5">
                    <div class="row gx-5 align-items-center justify-content-center">
                        <div class="col-lg-8 col-xl-7 col-xxl-6">
                            <div class="my-5 text-center text-xl-start">
                                <h1 class="display-5 fw-bolder text-white mb-2">Captura de datos, auditoría y automatización de procesos.</h1>
                                <p class="lead fw-normal text-white-50 mb-4">Consultoría en adquisición, análisis y presentación de datos, impulsada por inteligencia artificial y tecnologías seguras pensadas para PYMEs.</p>
                                <div class="d-grid gap-3 d-sm-flex justify-content-sm-center justify-content-xl-start">
                                    <a class="btn btn-primary btn-lg px-4 me-sm-3" href="#features">Get Started</a>
                                    <!--<a class="btn btn-outline-light btn-lg px-4" href="#!">Learn More</a>-->
                                </div>
                            </div>
                        </div>
                        <div class="col-xl-5 col-xxl-6 d-none d-xl-block text-center"><img class="img-fluid rounded-3 my-5" src="assets/hero.png" alt="..." /></div>
                    </div>
                </div>
            </header>
            <!-- Features section-->
            <section class="py-5" id="features">
                <div class="container px-5 my-5">
                    <div class="row gx-5">
                        <div class="col-lg-4 mb-5 mb-lg-0"><h2 class="fw-bolder mb-0">Soluciones para ordenar, automatizar y visualizar tus datos.</h2></div>
                        <div class="col-lg-8">
                            <div class="row gx-5 row-cols-1 row-cols-md-2">
                                <div class="col mb-5 h-100">
                                    <div class="feature bg-primary bg-gradient text-white rounded-3 mb-3"><i class="bi bi-collection"></i></div>
                                    <h2 class="h5">Ingesta e Integración de Sistemas</h2>
                                    <p class="mb-0">Integración de APIs, archivos, bases de datos y herramientas existentes para centralizar información dispersa en un flujo único y controlado.</p>
                                </div>
                                <div class="col mb-5 h-100">
                                    <div class="feature bg-primary bg-gradient text-white rounded-3 mb-3"><i class="bi bi-building"></i></div>
                                    <h2 class="h5">Automatización de procesos</h2>
                                    <p class="mb-0">Reducción de tareas manuales mediante procesos automáticos de captura, validación, transformación y actualización de datos.</p>
                                </div>
                                <div class="col mb-5 mb-md-0 h-100">
                                    <div class="feature bg-primary bg-gradient text-white rounded-3 mb-3"><i class="bi bi-toggles2"></i></div>
                                    <h2 class="h5">Reportes y dashboards</h2>
                                    <p class="mb-0">Desarrollo de tableros personalizados actualizados con datos en tiempo real para monitorear operaciones, estados e indicadores clave.</p>
                                </div>
                                <div class="col h-100">
                                    <div class="feature bg-primary bg-gradient text-white rounded-3 mb-3"><i class="bi bi-toggles2"></i></div>
                                    <h2 class="h5">Consulta inteligente de información</h2>
                                    <p class="mb-0">Implementación de sistemas de consulta sobre documentos, registros o bases internas, con apoyo de IA cuando el caso lo requiere.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Blog preview section-->
            <section class="py-5 bg-light">
                <div class="container px-5 my-5">
                    <div class="row gx-5 justify-content-center">
                        <div class="col-lg-8 col-xl-6">
                            <div class="text-center">
                                <h2 class="fw-bolder">Casos de aplicación</h2>
                                <p class="lead fw-normal text-muted mb-5">Ejemplos de soluciones para integrar datos, ordenar información y presentarla en sistemas útiles de monitoreo, consulta y gestión.</p>
                            </div>
                        </div>
                    </div>
                    <div class="row gx-5">
                        <div class="col-lg-4 mb-5">
                            <div class="card h-100 shadow border-0">
                                <img class="card-img-top" src="assets/weather.png" alt="Plataforma meteorológica municipal">
                                <div class="card-body p-4">
                                    <div class="badge bg-primary bg-gradient rounded-pill mb-2">Datos climáticos</div>
                                    <a class="text-decoration-none link-dark stretched-link" href="#!">
                                        <h5 class="card-title mb-3">Plataforma meteorológica municipal</h5>
                                    </a>
                                    <p class="card-text mb-0">
                                        Aplicación web para integrar APIs meteorológicas, registros históricos y reportes periódicos orientados al seguimiento climático.
                                    </p>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-4 mb-5">
                            <div class="card h-100 shadow border-0">
                                <img class="card-img-top" src="assets/seed.png" alt="Asistencia comunitaria para cultivo">
                                <div class="card-body p-4">
                                    <div class="badge bg-primary bg-gradient rounded-pill mb-2">Impacto social</div>
                                    <a class="text-decoration-none link-dark stretched-link" href="#!">
                                        <h5 class="card-title mb-3">Asistencia comunitaria para cultivo</h5>
                                    </a>
                                    <p class="card-text mb-0">
                                        Sistema que utiliza la localización del usuario para generar recomendaciones de cultivo según condiciones del entorno.
                                    </p>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-4 mb-5">
                            <div class="card h-100 shadow border-0">
                                <img class="card-img-top" src="assets/energy.png" alt="Monitoreo de energía sustentable">
                                <div class="card-body p-4">
                                    <div class="badge bg-primary bg-gradient rounded-pill mb-2">Monitoreo</div>
                                    <a class="text-decoration-none link-dark stretched-link" href="#!">
                                        <h5 class="card-title mb-3">Monitoreo de energía sustentable</h5>
                                    </a>
                                    <p class="card-text mb-0">
                                        Plataforma para registrar, ordenar y visualizar consumo eléctrico y generación de energía en instalaciones con paneles solares.
                                    </p>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-4 mb-5">
                            <div class="card h-100 shadow border-0">
                                <img class="card-img-top" src="assets/dashboard.png" alt="Dashboards operativos y bursátiles">
                                <div class="card-body p-4">
                                    <div class="badge bg-primary bg-gradient rounded-pill mb-2">Dashboards</div>
                                    <a class="text-decoration-none link-dark stretched-link" href="#!">
                                        <h5 class="card-title mb-3">Dashboards operativos y bursátiles</h5>
                                    </a>
                                    <p class="card-text mb-0">
                                        Paneles de monitoreo con ThingsBoard y gráficas en tiempo real a partir de fuentes de datos externas.
                                    </p>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-4 mb-5">
                            <div class="card h-100 shadow border-0">
                                <img class="card-img-top" src="assets/files.png" alt="Consulta documental sobre NAS">
                                <div class="card-body p-4">
                                    <div class="badge bg-primary bg-gradient rounded-pill mb-2">Consulta documental</div>
                                    <a class="text-decoration-none link-dark stretched-link" href="#!">
                                        <h5 class="card-title mb-3">Consulta documental sobre NAS</h5>
                                    </a>
                                    <p class="card-text mb-0">
                                        Sistema de búsqueda y consulta para localizar archivos almacenados en un NAS mediante indexación y recuperación de información.
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
            <!-- Testimonial section-->
            <div class="py-5">
                <div class="container px-5 my-5">
                    <div class="row gx-5 justify-content-center">
                      <div class="col-lg-4 mb-4 mb-lg-0 text-center">
                          <img class="img-fluid rounded-3 shadow" src="assets/sergio-pernas.png" alt="Sergio Pernas">
                      </div>
                      <div class="col-lg-8 col-xl-7">
                            <div class="text-center">
                                <div class="fs-4 mb-4 fst-italic">"La inteligencia artificial me interesa como herramienta de apoyo, no como reemplazo del criterio técnico. Para mí el valor está en entender el problema, ordenar los datos, construir una infraestructura confiable y usar cada tecnología en el lugar donde realmente aporta. La IA puede ayudar a consultar, resumir o acelerar procesos, pero la solución sigue dependiendo del diseño, del contexto y de las personas que conocen el negocio."</div>
                                <div class="d-flex align-items-center justify-content-center">
                                    <div class="fw-bold">
                                      Sergio Pernas.
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- Call to action-->
                    <aside class="bg-primary bg-gradient rounded-3 p-4 p-sm-5 mt-5">
                        <div class="d-flex align-items-center justify-content-between flex-column flex-xl-row text-center text-xl-start">
                            <div class="mb-4 mb-xl-0">
                                <div class="fs-3 fw-bold text-white">New products, delivered to you.</div>
                                <div class="text-white-50">Sign up for our newsletter for the latest updates.</div>
                            </div>
                            <div class="ms-xl-4">
                                <div class="input-group mb-2">
                                    <input class="form-control" type="text" placeholder="Email address..." aria-label="Email address..." aria-describedby="button-newsletter" />
                                    <button class="btn btn-outline-light" id="button-newsletter" type="button">Sign up</button>
                                </div>
                                <div class="small text-white-50">We care about privacy, and will never share your data.</div>
                            </div>
                        </div>
                    </aside>
                </div>
            </div>
        </main>
        <!-- Footer-->
        <footer class="bg-dark py-4 mt-auto">
            <div class="container px-5">
                <div class="row align-items-center justify-content-between flex-column flex-sm-row">
                    <div class="col-auto"><div class="small m-0 text-white">Copyright &copy; Your Website 2023</div></div>
                    <div class="col-auto">
                        <a class="link-light small" href="#!">Privacy</a>
                        <span class="text-white mx-1">&middot;</span>
                        <a class="link-light small" href="#!">Terms</a>
                        <span class="text-white mx-1">&middot;</span>
                        <a class="link-light small" href="#!">Contact</a>
                    </div>

                </div>
            </div>
        </footer>
        <!-- Bootstrap core JS-->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
        <!-- Core theme JS-->
        <script src="js/scripts.js"></script>
    </body>
